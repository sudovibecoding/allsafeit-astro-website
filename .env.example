# ─────────────────────────────────────────────────────────────────────
# Storyblok CMS (optional — for /demo/storyblok POC)
# Preview token from Storyblok → Space Settings → Access Tokens
STORYBLOK_TOKEN=

# Management API — required for `npm run storyblok:push-components`
# Account → Personal access tokens (Component + Story scopes)
STORYBLOK_MANAGEMENT_TOKEN=
STORYBLOK_SPACE_ID=

# ─────────────────────────────────────────────────────────────────────
# Email service — Resend
# ─────────────────────────────────────────────────────────────────────
# Used by `astro dev`. In production these come from wrangler.jsonc
# `vars` (non-secrets) and `wrangler secret put` (secrets).

# SECRET. Resend API key — get from https://resend.com/api-keys.
# Starts with "re_". Production: set via `wrangler secret put RESEND_API_KEY`.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default sender. Accepts plain email or "Name <email>" form.
# Domain must be verified in Resend.
EMAIL_FROM=AllSafe IT <form@allsafeit.com>

# Which environment this app is running as.
# Values: development | staging | production
APP_ENV=development

# REQUIRED when APP_ENV is not "production". Every send reroutes here.
# Leave blank or omit in production.
STAGING_EMAIL_OVERRIDE=giddythewebguy@gmail.com

# ─────────────────────────────────────────────────────────────────────
# Existing form-pipeline secrets (already in use)
# ─────────────────────────────────────────────────────────────────────
TURNSTILE_SECRET=
RECAPTCHA_SECRET=
