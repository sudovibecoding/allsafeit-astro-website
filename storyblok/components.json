[
  {
    "name": "page",
    "display_name": "Page",
    "is_root": true,
    "is_nestable": false,
    "schema": {
      "meta_title": {
        "type": "text",
        "display_name": "SEO Title",
        "description": "Browser tab / Google title"
      },
      "meta_description": {
        "type": "textarea",
        "display_name": "SEO Meta Description"
      },
      "canonical": {
        "type": "text",
        "display_name": "Canonical URL",
        "description": "Optional. Defaults to https://www.allsafeit.com/{slug}"
      },
      "preview_path": {
        "type": "text",
        "display_name": "Public URL path (reference)",
        "description": "Public path e.g. /services/managed-it/co-managed. Synced to Storyblok Real path via npm run storyblok:sync-paths. Space Preview URL should be only your dev origin, e.g. https://localhost:4322"
      },
      "indexable": {
        "type": "boolean",
        "display_name": "Allow search engines to index this page",
        "default_value": true
      },
      "schema_json": {
        "type": "textarea",
        "display_name": "Schema.org JSON-LD",
        "description": "JSON array of schema objects. Leave blank to use page defaults."
      },
      "use_seo_for_social": {
        "type": "boolean",
        "display_name": "Use SEO title & description for social sharing",
        "default_value": true
      },
      "featured_image": {
        "type": "asset",
        "filetypes": ["images"],
        "display_name": "Featured / social image",
        "description": "Used for Open Graph when no override is set. Falls back to site default."
      },
      "og_title": {
        "type": "text",
        "display_name": "Social share title (override)",
        "description": "Leave blank to use SEO title (when toggle above is on)."
      },
      "og_description": {
        "type": "textarea",
        "display_name": "Social share description (override)"
      },
      "og_image": {
        "type": "asset",
        "filetypes": ["images"],
        "display_name": "Social share image (override)"
      },
      "nav_heading": { "type": "text", "display_name": "Navigation menu label" },
      "project_number": { "type": "number", "display_name": "Nav sort order" },
      "publish_date": { "type": "text", "display_name": "Publish date (ISO, blog posts)" },
      "blog_category": { "type": "text", "display_name": "Blog category slug" },
      "service_category": { "type": "text", "display_name": "Service category slug" },
      "body": {
        "type": "bloks",
        "display_name": "Page sections",
        "restrict_components": true,
        "component_whitelist": [
          "hero_service",
          "hero_centered",
          "section_intro",
          "intro_split",
          "content_image_left",
          "content_image_right",
          "wide_image",
          "service_card_grid",
          "service_card_list",
          "value_metrics",
          "numbered_list_split",
          "why_choose_accordion",
          "tabs_section",
          "faq_section",
          "testimonials_slider",
          "contact_section",
          "contact_form_section",
          "contact_info_section",
          "legal_page",
          "reviews_grid",
          "custom_html",
          "hero_industry",
          "hero_service_detail",
          "service_detail_intro",
          "article_with_sidebar",
          "hero_blog_post",
          "blog_listing",
          "blog_category_listing",
          "author_profile",
          "related_posts",
          "industries_grid",
          "onboarding_process",
          "problems_grid",
          "service_areas",
          "location_cards"
        ]
      }
    }
  },
