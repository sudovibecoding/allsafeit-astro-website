---
import Base from '../../layouts/Base.astro';
import HeroService from '../../components/sections/HeroService.astro';
import SectionIntro from '../../components/sections/SectionIntro.astro';
import SplitContent from '../../components/sections/SplitContent.astro';
import ServiceCardList from '../../components/sections/ServiceCardList.astro';
import WhyChooseAccordion from '../../components/sections/WhyChooseAccordion.astro';
import LocationCards from '../../components/sections/LocationCards.astro';
import FaqSection from '../../components/sections/FaqSection.astro';
import ContactSection from '../../components/sections/ContactSection.astro';
import { IT_INFRASTRUCTURE_FAQS } from '../../data/faqs/it-infrastructure';
import type { ServiceItem } from '../../components/sections/ServiceCardList.astro';

// Sub-service detail pages don't exist as Tina entries yet — link the
// CTAs to the contact form anchor so the cards are still actionable.
const INFRA_HREF = '/contact-us#form';
const coreServices: ServiceItem[] = [
  {
    title: 'Server Management',
    description: 'Proactive monitoring, maintenance, and optimization of your physical and virtual servers. Maximum uptime, minimum surprises, and predictable performance.',
    href: INFRA_HREF,
  },
  {
    title: 'Network Infrastructure',
    description: 'Design, deploy, and manage reliable networks. Redundancy built in, performance tuned, security hardened. Networks that support how your business actually works.',
    href: INFRA_HREF,
  },
  {
    title: 'Microsoft Azure Management',
    description: 'Cloud infrastructure provisioned correctly, optimized for cost, and monitored continuously. We manage Azure so you get the benefits without the complexity.',
    href: INFRA_HREF,
  },
  {
    title: 'Microsoft 365 Administration',
    description: 'User provisioning, license management, Teams configuration, and ongoing optimization of your M365 environment for maximum productivity.',
    href: INFRA_HREF,
  },
  {
    title: 'Cloud Cost Optimization',
    description: 'Most businesses overspend on cloud by 30–40%. We find and eliminate waste while maintaining — and often improving — performance and reliability.',
    href: INFRA_HREF,
  },
  {
    title: 'Disaster Recovery & Business Continuity',
    description: 'Tested recovery plans that get your business back online fast when the unexpected happens. Backup strategies that actually work under pressure.',
    href: INFRA_HREF,
  },
];

