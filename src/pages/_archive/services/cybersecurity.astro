---
import Base from '../../layouts/Base.astro';
import HeroService from '../../components/sections/HeroService.astro';
import SectionIntro from '../../components/sections/SectionIntro.astro';
import SplitContent from '../../components/sections/SplitContent.astro';
import ServiceCardList from '../../components/sections/ServiceCardList.astro';
import WhyChooseAccordion from '../../components/sections/WhyChooseAccordion.astro';
import LocationCards from '../../components/sections/LocationCards.astro';
import FaqSection from '../../components/sections/FaqSection.astro';
import ContactSection from '../../components/sections/ContactSection.astro';
import { CYBERSECURITY_FAQS } from '../../data/faqs/cybersecurity';
import type { ServiceItem } from '../../components/sections/ServiceCardList.astro';

// Hrefs point at the contact-us form anchor — Cybersecurity sub-service
// detail pages don't exist yet as Tina entries; falling back to the contact
// form keeps the CTA functional. Swap to slugs as content is added.
const CYBER_HREF = '/contact-us#form';
const coreServices: ServiceItem[] = [
  {
    title: 'Endpoint Protection (EDR)',
    description: 'Advanced detection and response on every device. Stops ransomware, malware, and zero-day threats before they spread across your network.',
    href: CYBER_HREF,
  },
  {
    title: 'Email Security',
    description: 'Multi-layer protection against phishing, spam, and business email compromise — the #1 attack vector for small businesses.',
    href: CYBER_HREF,
  },
  {
    title: 'Managed Firewall',
    description: 'Next-gen firewall configured and monitored by our security team. Controls what gets in and out of your network, around the clock.',
    href: CYBER_HREF,
  },
  {
    title: 'Penetration Testing',
    description: 'Ethical hackers test your defenses before real attackers do. Identify and fix vulnerabilities on your own terms.',
    href: CYBER_HREF,
  },
  {
    title: 'Security Awareness Training',
    description: 'Turn your team from a liability into a security asset. Simulated phishing, training modules, and compliance reporting included.',
    href: CYBER_HREF,
  },
  {
    title: '24/7 Threat Monitoring (SIEM)',
    description: 'Centralized security monitoring across your entire IT environment. Threats detected and neutralized before they cause damage.',
    href: CYBER_HREF,
  },
];

// SVG icons extracted verbatim from Webflow cybersecurity.html
// "Additional Cybersecurity Services" section.
const SVG_640 = (path: string) =>
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" fill="currentColor"><path d="${path}"/></svg>`;
const SVG_512 = (path: string) =>
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" fill="currentColor"><path d="${path}"/></svg>`;

const additionalServices = [
  {
    label: 'Dark web monitoring',
