---
import Base from '../../layouts/Base.astro';
import HeroService from '../../components/sections/HeroService.astro';
import SectionIntro from '../../components/sections/SectionIntro.astro';
import SplitContent from '../../components/sections/SplitContent.astro';
import ServiceCardList from '../../components/sections/ServiceCardList.astro';
import WhyChooseAccordion from '../../components/sections/WhyChooseAccordion.astro';
import LocationCards from '../../components/sections/LocationCards.astro';
import FaqSection from '../../components/sections/FaqSection.astro';
import ContactSection from '../../components/sections/ContactSection.astro';
import { IT_CONSULTING_FAQS } from '../../data/faqs/it-consulting';
import type { ServiceItem } from '../../components/sections/ServiceCardList.astro';

// Sub-service detail pages don't exist as Tina entries yet — link the
// CTAs to the contact form anchor so the cards are still actionable.
const CONSULT_HREF = '/contact-us#form';
const coreServices: ServiceItem[] = [
  {
    title: 'vCIO Services',
    description: 'Strategic technology leadership without the full-time cost. Quarterly roadmaps, vendor management, budget planning, and executive-level technology guidance.',
    href: CONSULT_HREF,
  },
  {
    title: 'Technology Roadmap Planning',
    description: 'Align IT investments with business goals. Know exactly what to spend, when, and why — with no surprises and clear ROI at every stage.',
    href: CONSULT_HREF,
  },
  {
    title: 'Cloud Migration Consulting',
    description: 'Plan and execute migrations to Microsoft Azure and Microsoft 365 with minimal disruption, optimized cost, and maximum operational benefit.',
    href: CONSULT_HREF,
  },
  {
    title: 'IT Assessment Services',
    description: 'Comprehensive audit of your current environment. Identify gaps, risks, and opportunities before they become costly problems.',
    href: CONSULT_HREF,
  },
  {
    title: 'AI & Automation Consulting',
    description: 'AllSafe Intelligence helps automate repetitive tasks, integrate AI tools, and free your team to focus on high-value strategic work.',
    href: CONSULT_HREF,
  },
  {
    title: 'Vendor Management',
    description: "We manage your technology relationships so you don't have to. Better pricing, accountability, and results from every vendor you work with.",
    href: CONSULT_HREF,
  },
];

