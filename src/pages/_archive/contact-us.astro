---
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ContactForm from '../components/ContactForm.astro';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.allsafeit.com' },
      { '@type': 'ListItem', position: 2, name: 'Contact Us', item: 'https://www.allsafeit.com/contact-us' },
    ],
  },
];

const locations = [
  { city: 'Pasadena', address: '70 South Lake Ave, Suite 690', cityLine: 'Pasadena, CA 91101' },
  { city: 'Los Angeles', address: '1800 N. Vine St', cityLine: 'Los Angeles, CA 90028' },
  { city: 'Newport Beach', address: '4695 MacArthur Ct, 11th Floor', cityLine: 'Newport Beach, CA 92660' },
];
---

<Base
  title="Contact AllSafe IT | IT Support & Managed Services Provider"
  description="Get in touch with AllSafe IT to discuss Managed IT Services, Cybersecurity, or IT Support for your business. Our team is ready to help you plan next steps."
  canonical="https://www.allsafeit.com/contact-us"
  schema={schema}
>
  <div class="container">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Contact Us' }]} />
  </div>

  {/* ── Form section ── */}
  <section class="section">
    <div class="container">
      <div class="form-container">
        <div class="title">
          <div class="badge-text">[leave a message for us]</div>
          <h1 class="h3">Contact AllSafe IT for Reliable Business IT Solutions</h1>
        </div>
        <p class="h5 conversation-heading">Start the Conversation</p>
        <ContactForm />
      </div>
    </div>
  </section>

  {/* ── Contact info (dark box: phones + locations) ── */}
  <section class="section">
    <div class="container">
      <div class="contact-box">
        <h2 class="h4 color__white-shade1">Reach out to our team and we’ll respond ASAP.</h2>

        <div class="contact-phones">
          <div class="contact-phone">
            <div class="badge-text color__white-shade1">sales</div>
            <a href="tel:8884002748" class="lead-text strong color__white-shade1">(888) 400-2748</a>
          </div>
          <div class="contact-phone">
            <div class="badge-text color__white-shade1">support</div>
            <a href="tel:2137841959" class="lead-text strong color__white-shade1">(213) 784-1959</a>
          </div>
        </div>

        <div class="contact-locations">
          <div class="badge-text color__white-shade1">location</div>
          <div class="locations-grid">
            {locations.map((loc) => (
              <div class="location-card">
                <p class="location-text color__white-shade1">
                  <strong>{loc.city}:</strong><br />
                  {loc.address}<br />
                  {loc.cityLine}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Single-column form section (Webflow .form_-container: max-width 6-col,
     2rem gap, centered). 6-col = 690px is the Webflow value — was previously
     8-col (928px), which was visibly wider than the live site. */
  .form-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    width: 100%;
    max-width: var(--container-6col);
    margin-left: auto;
    margin-right: auto;
  }
  .form-container .title {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .conversation-heading { margin: 0; }

  /* Dark contact-box: heading + phones row + locations grid. */
  .contact-box {
    background-color: var(--color-brand-dark);
    border-radius: var(--radius-large);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .contact-box .h4 { margin: 0; }

  .contact-phones {
    display: flex;
    flex-wrap: wrap;
    gap: 3rem;
  }
  .contact-phone {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .contact-phone a {
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .contact-phone a:hover { opacity: 0.8; }

  .contact-locations {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .locations-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .location-text {
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 991px) {
    .contact-box { padding: 2rem; }
    .locations-grid { grid-template-columns: 1fr; gap: 1.25rem; }
  }
</style>
