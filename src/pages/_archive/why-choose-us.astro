---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import Icon from '../components/primitives/Icon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import HeroCentered from '../components/sections/HeroCentered.astro';
import SplitContent from '../components/sections/SplitContent.astro';
import Tabs from '../components/sections/Tabs.astro';
import ContactSection from '../components/sections/ContactSection.astro';

// "The problems we solve" — Webflow tabs. Each pane: You say / We deliver /
// The final picture (accent labels via .color__lightblue).
const problemTabs = [
  {
    label: 'Slow IT Support & Disruptive Downtime',
    content: `<span class="color__lightblue">You say:</span> We can’t afford to be down, but our current IT provider takes hours (or days) to respond.<br><br><span class="color__lightblue">We deliver:</span> 24/7/365 managed IT support with a real team — not outsourced call centers. With our 99.999% uptime record and proactive monitoring, we identify and resolve issues before they impact productivity.<br><br><span class="color__lightblue">The final picture:</span> Your team works without interruptions, and IT becomes a background function — just as it should be.`,
  },
  {
    label: 'Cybersecurity threats and fear of data breach',
    content: `<span class="color__lightblue">You say:</span> Cyber risks keep me up at night. I don’t know if our business is truly protected.<br><br><span class="color__lightblue">We deliver:</span> Security for businesses across Los Angeles with managed firewalls, email protection, penetration testing, data backups, and ransomware prevention tools. More importantly, we educate your people with real-world security awareness training to prevent human-error breaches.<br><br><span class="color__lightblue">The final picture:</span> Stronger Los Angeles business security, lower risk exposure, and confidence that your data is protected from evolving threats.`,
  },
  {
    label: 'Compliance concerns (HIPAA, Finance, Education)',
    content: `<span class="color__lightblue">You say:</span> We’re in a regulated industry. One mistake could cost us everything.<br><br><span class="color__lightblue">We deliver:</span> IT audit and compliance services that help ensure your systems meet industry regulations like HIPAA, PCI, and SOC requirements. We identify vulnerabilities early, strengthen access control, and document your compliance for audit readiness.<br><br><span class="color__lightblue">The final outcome:</span> No more guessing — just clarity, protection, and peace of mind.`,
  },
  {
    label: 'Technology feels overwhelming',
    content: `<span class="color__lightblue">You say:</span> We don't have an internal IT department — managing everything is just too much.<br><br><span class="color__lightblue">We deliver:</span> Managed IT services in Los Angeles, CA, that act as your dedicated IT department. From helpdesk to infrastructure, we handle technology so you can focus on running your business — without needing technical expertise.<br><br><span class="color__lightblue">The final picture:</span> IT stress disappears. Productivity goes up. Teams feel supported.`,
  },
  {
    label: 'IT isn’t aligned with business goals',
    content: `<span class="color__lightblue">You say:</span> We’re growing, but our IT systems feel outdated and disconnected from our goals.<br><br><span class="color__lightblue">We deliver:</span> Virtual CIO (vCIO) services that align your technology roadmap with your business strategy. Whether you’re scaling, opening new offices, or modernizing workflows, we help you use technology as a strategic growth enabler — not just a utility.<br><br><span class="color__lightblue">The final picture:</span> IT shifts from being a cost center to a growth catalyst.`,
  },
  {
    label: 'Internal IT teams are overloaded',
    content: `<span class="color__lightblue">You say:</span> We have an IT person but they’re overwhelmed — we need backup without replacing them.<br><br><span class="color__lightblue">We deliver:</span> Co-managed IT services, supporting your existing tech team with extra manpower, tools, and elevated security capabilities. You stay in control — we empower your team to perform at a higher level.<br><br><span class="color__lightblue">The final picture:</span> Your IT staff feels supported — not replaced. Your business scales without burnout.`,
  },
];

// "Built to support growing businesses" — 4 service cards (image + bullets).
const builtCards = [
  {
    heading: 'Managed IT services',
    image: '/images/manageditservices.jpg',
    alt: 'AllSafe IT managing IT services',
    items: [
      'Full-service managed IT services',
      'Co-managed IT services for internal teams',
      '24/7 IT support in Los Angeles',
      'Proactive monitoring and maintenance',
      'Friendly helpdesk support',
    ],
  },
  {
    heading: 'IT consulting',
    image: '/images/ITconsulting.jpg',
    alt: 'IT consulting experts',
    items: [
      'Technology Alignment Process',
      'Virtual CIO (vCIO) strategies',
      'Microsoft 365 optimization and automation',
      'IT audit & compliance',
      'Robotic Process Automation (RPA)',
      'Application development and modernization',
    ],
  },
  {
    heading: 'Cybersecurity',
    image: '/images/Cybersecurity.avif',
    alt: 'AllSafe IT cybersecurity solutions',
    items: [
      'Cybersecurity & antivirus',
      'Managed firewall and access control',
      'Email protection and anti-phishing tools',
      'Security awareness training',
      'Penetration testing and ongoing threat monitoring',
      'Data backups and disaster recovery',
    ],
  },
  {
    heading: 'IT infrastructure',
    image: '/images/It-infrastructure.jpg',
    alt: 'IT infrastructure experts',
    items: [
      'Infrastructure as a Service (IaaS)',
      'Network setup and cabling',
      'Cloud migration and integration',
      'VoIP and ISP services',
      'Surveillance & DVR solutions',
    ],
  },
];

// "AI enhancement through AllSafe Intelligence" — 4 icon cards.
const aiCards = [
  {
    heading: 'AI audits and workflow assessments',
    body: 'We identify automation opportunities that deliver measurable ROI.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true"><path d="M256 128C256 110.3 270.3 96 288 96L352 96C369.7 96 384 110.3 384 128L384 192C384 209.7 369.7 224 352 224L344 224L344 288L464 288C503.8 288 536 320.2 536 360L536 416L544 416C561.7 416 576 430.3 576 448L576 512C576 529.7 561.7 544 544 544L480 544C462.3 544 448 529.7 448 512L448 448C448 430.3 462.3 416 480 416L488 416L488 360C488 346.7 477.3 336 464 336L344 336L344 416L352 416C369.7 416 384 430.3 384 448L384 512C384 529.7 369.7 544 352 544L288 544C270.3 544 256 529.7 256 512L256 448C256 430.3 270.3 416 288 416L296 416L296 336L176 336C162.7 336 152 346.7 152 360L152 416L160 416C177.7 416 192 430.3 192 448L192 512C192 529.7 177.7 544 160 544L96 544C78.3 544 64 529.7 64 512L64 448C64 430.3 78.3 416 96 416L104 416L104 360C104 320.2 136.2 288 176 288L296 288L296 224L288 224C270.3 224 256 209.7 256 192L256 128z"/></svg>`,
  },
  {
    heading: 'Custom AI integrations',
    body: 'We connect existing tools and systems for seamless, intelligent operations.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true"><path d="M352 64C352 46.3 337.7 32 320 32C302.3 32 288 46.3 288 64L288 128L192 128C139 128 96 171 96 224L96 448C96 501 139 544 192 544L448 544C501 544 544 501 544 448L544 224C544 171 501 128 448 128L352 128L352 64zM160 432C160 418.7 170.7 408 184 408L216 408C229.3 408 240 418.7 240 432C240 445.3 229.3 456 216 456L184 456C170.7 456 160 445.3 160 432zM280 432C280 418.7 290.7 408 304 408L336 408C349.3 408 360 418.7 360 432C360 445.3 349.3 456 336 456L304 456C290.7 456 280 445.3 280 432zM400 432C400 418.7 410.7 408 424 408L456 408C469.3 408 480 418.7 480 432C480 445.3 469.3 456 456 456L424 456C410.7 456 400 445.3 400 432zM224 240C250.5 240 272 261.5 272 288C272 314.5 250.5 336 224 336C197.5 336 176 314.5 176 288C176 261.5 197.5 240 224 240zM368 288C368 261.5 389.5 240 416 240C442.5 240 464 261.5 464 288C464 314.5 442.5 336 416 336C389.5 336 368 314.5 368 288zM64 288C64 270.3 49.7 256 32 256C14.3 256 0 270.3 0 288L0 384C0 401.7 14.3 416 32 416C49.7 416 64 401.7 64 384L64 288zM608 256C590.3 256 576 270.3 576 288L576 384C576 401.7 590.3 416 608 416C625.7 416 640 401.7 640 384L640 288C640 270.3 625.7 256 608 256z"/></svg>`,
  },
  {
    heading: 'Process automation',
    body: 'We eliminate manual data entry, reduce errors, and streamline business functions.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true"><path d="M448.4 404C424.1 404 404.4 423.7 404.5 448.1C404.5 472.4 424.2 492 448.5 492C472.8 492 492.5 472.3 492.5 448C492.4 423.6 472.7 404 448.4 404zM192.4 148C168.1 148 148.4 167.7 148.4 192C148.4 216.3 168.1 236 192.4 236C216.7 236 236.4 216.3 236.4 192C236.4 167.7 216.7 148 192.4 148zM320 240C284.7 240 256 268.7 256 304C256 339.3 284.7 368 320 368C355.3 368 384 339.3 384 304C384 268.7 355.3 240 320 240z"/></svg>`,
  },
  {
    heading: 'AI-powered business dashboards',
    body: 'We provide real-time visibility for improved performance and decision-making.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true"><path d="M256 144C256 117.5 277.5 96 304 96L336 96C362.5 96 384 117.5 384 144L384 496C384 522.5 362.5 544 336 544L304 544C277.5 544 256 522.5 256 496L256 144zM64 336C64 309.5 85.5 288 112 288L144 288C170.5 288 192 309.5 192 336L192 496C192 522.5 170.5 544 144 544L112 544C85.5 544 64 522.5 64 496L64 336zM496 160L528 160C554.5 160 576 181.5 576 208L576 496C576 522.5 554.5 544 528 544L496 544C469.5 544 448 522.5 448 496L448 208C448 181.5 469.5 160 496 160z"/></svg>`,
  },
];

// Shield icon for the prevents-downtime wide-flow.
const shieldIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" fill="currentColor" aria-hidden="true"><path d="M320 64C324.6 64 329.2 65 333.4 66.9L521.8 146.8C543.8 156.1 560.2 177.8 560.1 204C559.6 303.2 518.8 484.7 346.5 567.2C329.8 575.2 310.4 575.2 293.7 567.2C121.3 484.7 80.6 303.2 80.1 204C80 177.8 96.4 156.1 118.4 146.8L306.7 66.9C310.9 65 315.4 64 320 64zM320 130.8L320 508.9C458 442.1 495.1 294.1 496 205.5L320 130.9L320 130.9z"/></svg>`;

const maps = [
  { label: 'Pasadena, California', src: 'https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d13208.024893715408!2d-118.1468895!3d34.1461829!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2bf205ed5fb19%3A0xe770eec7ff0a3b17!2sAllSafe%20IT!5e0!3m2!1sen!2sza!4v1705154134247!5m2!1sen!2sza' },
  { label: 'Los Angeles, California', src: 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3302.868447971743!2d-118.3334559!3d34.0977273!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2bf3f82ae1c73%3A0xb17c1716e1b7fdf!2sAllSafe%20IT!5e0!3m2!1sen!2sus!4v1731264900000!5m2!1sen!2sus' },
  { label: 'Newport Beach, California', src: 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3311.9729987565153!2d-117.874827!3d33.6640821!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80dcdfb3be1d40d5%3A0x4fced2a6efe020b!2s3848%20Campus%20Dr%20%23219%2C%20Newport%20Beach%2C%20CA%2092660%2C%20USA!5e0!3m2!1sen!2sph!4v1728324070000!5m2!1sen!2sph' },
];

const awards = [
  { src: '/images/top_clutch.co_it_services_company_retail_california.avif', alt: 'AllSafe IT — Top IT Services Company by Clutch' },
  { src: '/images/top_it_provider.avif', alt: 'Top IT Provider Award by UpCity for AllSafe IT' },
  { src: '/images/top_clutch.co_help_desk_service_provider_los_angeles_2023.avif', alt: 'Clutch Top Help Desk Service Provider Los Angeles Award' },
  { src: '/images/Compliancy-Group---HIPAA.avif', alt: 'AllSafe IT HIPAA Compliant badge' },
];

// Industry CMS cards (with images) for the "Comprehensive technology
// services for every sector" section.
const industries = (
  await getCollection(
    'industries',
    (e) => e.data.status !== 'archived' && e.data.status !== 'draft',
  )
).sort((a, b) => (a.data.projectNumber ?? 999) - (b.data.projectNumber ?? 999));

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.allsafeit.com' },
      { '@type': 'ListItem', position: 2, name: 'Why Choose Us', item: 'https://www.allsafeit.com/why-choose-us' },
    ],
  },
];
---

<Base
  title="Why Choose AllSafe IT | Trusted Outsourced IT in Los Angeles"
  description="Discover why California businesses choose AllSafe IT for managed IT services. SOC 2 certified, 97% CSAT, 98% retention, 20+ years serving Southern California."
  canonical="https://www.allsafeit.com/why-choose-us"
  schema={schema}
>
  <HeroCentered badge="[Why choose us]" title="Why choose AllSafe IT: Trusted outsourced IT in Los Angeles" />

  <div class="container">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Why Choose Us' }]} />
  </div>

  {/* ── Prevents downtime + wide-flow ── */}
  <section class="section">
    <div class="container">
      <div class="grid align-top">
        <div class="content loose">
          <div class="title">
            <h2 class="h3">AllSafe IT prevents downtime and cyber risks</h2>
          </div>
          <div class="body-text">
            At AllSafe IT we provide outsourced IT in Los Angeles built around one core belief: <strong>Diagnose first. Prescribe second.</strong> Because great IT support isn’t about selling services — it’s about understanding people, solving problems, and protecting what matters most to your business.<br /><br />
            With a 99.999% uptime track record, 24/7/365 support, and a friendly, human approach, AllSafe IT helps businesses eliminate IT stress, boost productivity, and strengthen cybersecurity — without the complexity or sales pressure that often comes with traditional IT vendors.
          </div>
        </div>
        <div class="wide-flow-wrap">
          <div class="parallax-wrap">
            <img src="/images/cybersecurity__allsafeit.jpg" alt="AllSafe IT cybersecurity-focused IT solutions" class="parallax-image" loading="lazy" />
          </div>
          <div class="wide-flow">
            <div class="flow-item">
              <img src="/images/personalized-it-support.jpg" alt="Personalized IT support" class="flow-image" loading="lazy" />
              <div class="badge-text flow-item-text">IT support</div>
            </div>
            <div class="flow-wide-line" aria-hidden="true"></div>
            <div class="flow-item">
              <div class="flow-icon"><div class="widget__embed-icons color__white-shade1" set:html={shieldIcon} /></div>
              <div class="badge-text flow-item-text">cybersecurity-focused IT solutions</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ── Transform (image left) ── */}
  <SplitContent
    heading="Transform your business with our cybersecurity-focused IT solutions"
    image="/images/DSC_2042DSC_2041.avif"
    imageAlt="AllSafe IT experts in a strategy conference"
    bg="gradient"
  >
    <p class="body-text">We believe in the power of technology to transform businesses. Our approach is centered around understanding your specific needs and crafting strategic IT solutions that propel you forward.</p>
    <p class="body-text">We’ve helped countless clients navigate the complexities of IT infrastructure, cybersecurity, and strategic planning with our comprehensive suite of services — offering not just technical expertise but strategic foresight that aligns IT with business goals.</p>
    <p class="body-text">From a non-profit we brought back from the brink of a cybersecurity disaster, to a small retail business we helped scale with strategic IT investments, our clients’ successes speak volumes.</p>
  </SplitContent>

  {/* ── Built to support growing businesses ── */}
  <section class="section">
    <div class="container">
      <div class="section-content">
        <div class="centered-title">
          <h2 class="h3 text_center">Built to support growing businesses</h2>
        </div>
        <div class="built-grid">
          {builtCards.map((card) => (
            <div class="built-card">
              <div class="parallax-wrap">
                <img src={card.image} alt={card.alt} class="parallax-image" loading="lazy" />
              </div>
              <div class="built-card-body">
                <h3 class="h4">{card.heading}</h3>
                <ul class="built-list body-text">
                  {card.items.map((item) => <li>{item}</li>)}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ── The problems we solve — TABS ── */}
  <div class="section padding-small bg-gradient">
    <div class="container">
      <div class="section-content">
        <div class="centered-title">
          <h2 class="h3 text_center">The problems we solve</h2>
          <p class="lead-text text_center">Technology should work as one system. Managed IT keeps your business running smoothly. Cybersecurity keeps you protected. AI multiplies what your team accomplishes.</p>
        </div>
        <Tabs tabs={problemTabs} initial={1} />
      </div>
    </div>
  </div>

  {/* ── AI enhancement ── */}
  <section class="section padding-top-small">
    <div class="container">
      <div class="section-content">
        <div class="content_grid">
          <div class="title">
            <h2 class="h3">AI enhancement through AllSafe Intelligence</h2>
          </div>
          <div class="lead-text">
            At AllSafe IT, innovation doesn’t stop at managed services. Through AllSafe Intelligence, we help Los Angeles and Orange County businesses move from spreadsheets to smart automation. We build <strong>AI solutions that fit your workflow</strong>, not the other way around — eliminating repetitive tasks, improving visibility, and giving teams time to focus on strategy instead of manual work.
          </div>
        </div>
        <div class="card-grid">
          {aiCards.map((card) => (
            <div class="icon-card">
              <div class="boxed-icon bg__color-blue">
                <div class="widget__embed-icons" set:html={card.icon} />
              </div>
              <div class="icon-card-content">
                <h3 class="h5 bold">{card.heading}</h3>
                <div class="lead-text body-text">{card.body}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ── Comprehensive technology services for every sector (industry CMS) ── */}
  <section class="section">
    <div class="container">
      <div class="section-content">
        <div class="centered-title">
          <h2 class="h3 text_center">Comprehensive technology services for every sector</h2>
        </div>
        <div class="sectors-grid">
          {industries.map((ind) => (
            <a href={`/industries/${ind.id}`} class="sector-card">
              <div class="sector-image">
                <img src={ind.data.featuredImage} alt={ind.data.featuredImageAlt ?? ind.data.name} loading="lazy" />
              </div>
              <div class="sector-content">
                <h3 class="h5">{ind.data.name}</h3>
                {ind.data.shortDescriptionForCards && <p class="lead-text body-text">{ind.data.shortDescriptionForCards}</p>}
                <div class="button-flex">
                  <span class="badge-text-blue">Learn more</span>
                  <Icon name="arrow-right" class="small_icon color__lightblue" />
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ── Managed services for small business (content left, image right) ── */}
  <SplitContent
    heading="Managed services for small business"
    image="/images/ITconsulting.jpg"
    imageAlt="AllSafe IT consulting experts for small business"
    imageRight
  >
    <p class="body-text">Many IT companies design their services for enterprises — leaving small and growing businesses stuck with overpriced, overbuilt solutions. AllSafe IT is different. We’re known as the best MSP for small business partners who want enterprise-level protection without enterprise-level complexity.</p>
    <p class="body-text">And for businesses with internal IT staff, our co-managed IT services approach adds power without taking control away.</p>
    <p class="body-text">Whether you’re just starting to outsource IT or looking to elevate your IT operations, we’re here to support your growth — not restrict it.</p>
  </SplitContent>

  {/* ── Locations (map cards) ── */}
  <div class="section">
    <div class="container">
      <div class="section-content">
        <div class="centered-title">
          <h2 class="h3 text_center">Secure your business:<br />AllSafe IT prevents downtime and cyber risks</h2>
        </div>
        <div class="map-grid">
          {maps.map((m) => (
            <div class="map-card">
              <div class="map-frame">
                <iframe src={m.src} width="100%" height="100%" style="border:0;" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title={`AllSafe IT — ${m.label}`}></iframe>
              </div>
              <div class="map-blur-box"><h3 class="h5">{m.label}</h3></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  {/* ── Awards ── */}
  <section class="section">
    <div class="container">
      <div class="section-content">
        <div class="content_grid">
          <div class="title">
            <h2 class="h3">Awards, certifications &amp; industry trust</h2>
          </div>
          <div class="content">
            <div class="lead-text body-text">We’re proud to be recognized among the <strong>top MSPs in the nation</strong>, but even more proud that our growth is driven by customer trust.<br /><br />These aren’t just badges — they’re a reflection of consistent service, loyal clients, and a team that genuinely cares.</div>
          </div>
        </div>
        <div class="awards-row">
          {awards.map((a, i) => (
            <>
              {i > 0 && <div class="awards-line" aria-hidden="true"></div>}
              <div class="award-badge"><img src={a.src} alt={a.alt} loading="lazy" /></div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ContactSection />
</Base>

<style>
  /* ── Parallax image wrap (shared look with the About page). ── */
  .parallax-wrap {
    aspect-ratio: 3 / 2;
    border-radius: var(--radius-default);
    width: 100%;
    overflow: hidden;
    position: relative;
  }
  .parallax-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .content.loose { gap: 36px; }

  /* ── Prevents-downtime wide-flow overlay ── */
  .wide-flow-wrap {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .wide-flow {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 6px;
    align-items: center;
    justify-content: center;
    margin: -48px 48px 0;
  }
  .flow-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    max-width: 156px;
    padding: 12px;
    border-radius: var(--radius-default);
    background-color: var(--color-brand-primary);
    color: var(--color-light-1);
    text-align: center;
  }
  .flow-image {
    width: 144px;
    height: 144px;
    object-fit: cover;
    border-radius: var(--radius-default);
  }
  .flow-icon {
    width: 144px;
    height: 144px;
    border-radius: var(--radius-default);
    background-color: var(--color-dark-border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .flow-icon .widget__embed-icons { width: 3rem; }
  .flow-item-text { color: var(--color-light-1); }
  .flow-wide-line {
    flex: 1;
    border-bottom: 1px dotted var(--color-brand-dark);
  }

  /* ── Built to support: 2×2 image+bullets cards ── */
  .built-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .built-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background-color: var(--color-light-1);
    border-radius: var(--radius-default);
    overflow: hidden;
  }
  .built-card .parallax-wrap { border-radius: 0; }
  .built-card-body {
    display: flex;
    flex-direction: column;
