---
/**
 * Remote Support — `/support`.
 *
 * Webflow reference: `support.html` — centered hero with badge + H2 heading,
 * 2-up "portal" cards (AllSafe App + Billing portal), then a "Helpful links"
 * grid (4 download/welcome cards), then the standard Contact CTA.
 *
 * Content + SEO are copied verbatim from the Webflow source. The hero
 * background is the light `bg-gradient`, so headings render in dark brand
 * type (not `color__white-shade1` like our earlier version which made the
 * H1 unreadable against the pale gradient).
 *
 * The shared `Breadcrumb` component replaces the inline breadcrumb markup
 * that previously duplicated the design system's crumb styling.
 */
import Base from '../layouts/Base.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ContactSection from '../components/sections/ContactSection.astro';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.allsafeit.com' },
      { '@type': 'ListItem', position: 2, name: 'Remote Support', item: 'https://www.allsafeit.com/support' },
    ],
  },
];

const helpfulLinks = [
  {
    title: 'AllSafe App — Windows',
    description: 'Download the AllSafe remote support app for Windows.',
    href: 'https://forms.allsafeit.com/wp-content/downloads/AllSafeApp-v4-6-0-0.zip',
    label: 'Download ZIP',
  },
  {
    title: 'AllSafe App — MacOS',
    description: 'Download the AllSafe remote support app for macOS.',
    href: 'https://forms.allsafeit.com/wp-content/uploads/2024/05/AllSafeAppMac_v6.zip',
    label: 'Download ZIP',
  },
  {
    title: 'SOS Instant Remote Support',
    description: 'One-click remote session for urgent support.',
    href: 'https://sos.allsafeit.com/',
    label: 'Go to SOS Support',
  },
  {
    title: 'New Clients Welcome Page',
    description: 'Onboarding resources and setup guides for new clients.',
    href: '/new-client-page',
    label: 'Go to Welcome Page',
  },
];
---

<Base
  title="Remote Business Support by AllSafe IT"
  description="Remote IT support, IT assistance, AllSafe App, billing portal, IT helpdesk, technical support services with AllSafe IT."
  canonical="https://www.allsafeit.com/support"
  schema={schema}
>
  <div aria-hidden="true" style="height: var(--navbar-height)"></div>

  {/* Centered hero — badge + H1 on the light gradient. */}
  <section class="section bg-gradient support-hero">
    <div class="container">
      <div class="support-hero-inner">
        <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Remote Support' }]} />
        <p class="badge-text">[Remote support]</p>
        <h1 class="h2 text_center">AllSafe IT Remote Support: App, Billing Portal &amp; Resources</h1>
      </div>
    </div>
  </section>

  {/* 2-up dark portal cards — AllSafe App + Billing portal. */}
  <section class="section">
    <div class="container">
      <div class="portal-grid">
        <a href="https://app.allsafeit.com" target="_blank" rel="noopener noreferrer" class="portal-card">
          <div class="portal-card-inner">
            <h2 class="h4 color__white-shade1">AllSafe App</h2>
            <p class="lead-text color__white-shade1">Enjoy seamless access to your services, resources, and support here.</p>
            <span class="portal-cta">Visit the AllSafe App &rarr;</span>
          </div>
        </a>
        <a href="https://pay.allsafeit.com/" target="_blank" rel="noopener noreferrer" class="portal-card">
          <div class="portal-card-inner">
            {/* Webflow uses "Billing portal" (lowercase p) — match exactly. */}
            <h2 class="h4 color__white-shade1">Billing portal</h2>
            <p class="lead-text color__white-shade1">View your invoices and manage your billing preferences here.</p>
            <span class="portal-cta">Visit Billing Portal &rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  {/* "Helpful links" — secondary download/welcome grid on the gradient bg. */}
  <section class="section bg-gradient">
    <div class="container">
      <div class="section-content">
        <div class="content_grid">
          <div class="title">
            <h2 class="h3">Helpful links</h2>
          </div>
        </div>
        <div class="links-grid">
          {helpfulLinks.map(link => (
            <a
              href={link.href}
              class="link-card"
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              <h3 class="h5">{link.title}</h3>
              <p class="body-text">{link.description}</p>
              <span class="link-cta">{link.label} &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ContactSection heading="Ready to transform your IT? Contact us today!" />
</Base>

<style>
  .support-hero {
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  /* Centered title block — badge + H1 stacked, max-width capped to 8 cols so
     the headline reads on two lines at desktop. */
  .support-hero-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: var(--container-8col);
    margin: 0 auto;
    text-align: center;
    align-items: center;
  }
  .support-hero-inner .h2 { margin: 0; }
  .support-hero-inner .badge-text { color: var(--color-accent); margin: 0; }

  /* 2-up portal cards — dark brand fill, big tap surface. Hover lifts the
     card with a soft shadow (matches the rest of the site's link-card UX). */
  .portal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .portal-card {
    display: block;
    text-decoration: none;
    border-radius: var(--radius-default);
    background: var(--color-brand-dark);
    color: var(--color-text-light);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    min-height: 220px;
  }
  .portal-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 25, 68, 0.2);
  }
  .portal-card-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2.5rem;
    height: 100%;
  }
  .portal-card .h4 { margin: 0; }
  .portal-card .lead-text { margin: 0; opacity: 0.85; }
  .portal-cta {
    font-size: var(--text-lead);
    font-weight: 600;
    color: var(--color-accent);
    margin-top: auto;
  }

  /* "Helpful links" 2-up grid — translucent surface that reads cleanly on
     the gradient background. */
  .links-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: var(--spacing-section-sm);
  }
  .link-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.75rem;
    background: var(--color-light-1);
    border: 1px solid var(--color-dark-border, rgba(0, 25, 68, 0.08));
    border-radius: var(--radius-default);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .link-card:hover {
    background: var(--color-light-2);
    transform: translateY(-2px);
  }
  .link-card .h5 { margin: 0; color: var(--color-brand-dark); }
  .link-card .body-text { margin: 0; color: var(--color-text-dark-body); }
  .link-cta {
    font-size: var(--text-lead);
    font-weight: 600;
    color: var(--color-accent);
    margin-top: auto;
  }

  @media (max-width: 767px) {
    .portal-grid { grid-template-columns: 1fr; }
    .links-grid { grid-template-columns: 1fr; }
  }
</style>
