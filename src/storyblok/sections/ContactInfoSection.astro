---
interface LocationBlok {
  city?: string;
  address?: string;
  city_line?: string;
}

interface Props {
  blok: {
    heading?: string;
    sales_phone?: string;
    support_phone?: string;
    locations?: LocationBlok[];
  };
}

const { blok } = Astro.props;
const locations = blok.locations ?? [];
---

<section class="section">
  <div class="container">
    <div class="contact-box">
      <h2 class="h4 color__white-shade1">
        {blok.heading ?? "Reach out to our team and we'll respond ASAP."}
      </h2>
      <div class="contact-phones">
        {blok.sales_phone && (
          <div class="contact-phone">
            <div class="badge-text color__white-shade1">sales</div>
            <a href={`tel:${blok.sales_phone.replace(/\D/g, '')}`} class="lead-text strong color__white-shade1">
              {blok.sales_phone}
            </a>
          </div>
        )}
        {blok.support_phone && (
          <div class="contact-phone">
            <div class="badge-text color__white-shade1">support</div>
            <a href={`tel:${blok.support_phone.replace(/\D/g, '')}`} class="lead-text strong color__white-shade1">
              {blok.support_phone}
            </a>
          </div>
        )}
      </div>
      {locations.length > 0 && (
        <div class="contact-locations">
          <div class="badge-text color__white-shade1">location</div>
          <div class="locations-grid">
            {locations.map((loc) => (
              <div class="location-card">
                <p class="location-text color__white-shade1">
                  <strong>{loc.city}:</strong><br />
                  {loc.address}<br />
                  {loc.city_line}
                </p>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .contact-box {
    background-color: var(--color-brand-dark);
    border-radius: var(--radius-large);
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .contact-box .h4 { margin: 0; }
  .contact-phones { display: flex; flex-wrap: wrap; gap: 3rem; }
  .contact-phone { display: flex; flex-direction: column; gap: 0.25rem; }
  .contact-locations { display: flex; flex-direction: column; gap: 1rem; }
  .locations-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .location-text { margin: 0; }
  @media (max-width: 991px) {
    .locations-grid { grid-template-columns: 1fr; }
  }
</style>
