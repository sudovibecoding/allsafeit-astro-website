---
import ContentImageSplit from '../../components/sections/ContentImageSplit.astro';
import { renderBodyContentInner } from '../../lib/storyblok-richtext';
import { storyblokAssetUrl } from '../../lib/storyblok-asset';

interface ButtonBlok {
  label?: string;
  href?: string;
  style?: 'button' | 'link';
}

interface Props {
  blok: {
    heading: string;
    image: { filename?: string } | string;
    image_alt?: string;
    image_right?: boolean;
    background?: 'white' | 'gradient';
    body?: unknown;
    buttons?: ButtonBlok[];
  };
}

const { blok } = Astro.props;
const image = storyblokAssetUrl(blok.image) ?? '';
const bodyHtml = renderBodyContentInner(blok.body);
const buttons = (blok.buttons ?? [])
  .map((b) => ({
    label: b.label ?? 'Learn more',
    href: b.href ?? '#',
    style: b.style ?? 'button',
  }))
  .filter((b) => b.label);
---

<ContentImageSplit
  heading={blok.heading}
  bodyHtml={bodyHtml}
  image={image}
  imageAlt={blok.image_alt ?? ''}
  imageRight={blok.image_right ?? false}
  bg={blok.background ?? 'white'}
  buttons={buttons}
/>
