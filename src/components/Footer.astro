const instagramSvg = `<svg width="18" height="19" viewBox="0 0 18 19" fill="none" xmlns="http://www.w3.org/2000/svg"><g clip-path="url(#ig)"><path d="M9 2.2877C11.4047 2.2877 11.6895 2.29824 12.6352 2.34043C13.5141 2.3791 13.9887 2.52676 14.3051 2.6498C14.7234 2.81152 15.0258 3.0084 15.3387 3.32129C15.6551 3.6377 15.8484 3.93652 16.0102 4.35488C16.1332 4.67129 16.2809 5.14941 16.3195 6.0248C16.3617 6.97402 16.3723 7.25879 16.3723 9.65996C16.3723 12.0646 16.3617 12.3494 16.3195 13.2951C16.2809 14.174 16.1332 14.6486 16.0102 14.965C15.8484 15.3834 15.6516 15.6857 15.3387 15.9986C15.0223 16.315 14.7234 16.5084 14.3051 16.6701C13.9887 16.7932 13.5105 16.9408 12.6352 16.9795C11.6859 17.0217 11.4012 17.0322 9 17.0322C6.59531 17.0322 6.31055 17.0217 5.36484 16.9795C4.48594 16.9408 4.01133 16.7932 3.69492 16.6701C3.27656 16.5084 2.97422 16.3115 2.66133 15.9986C2.34492 15.6822 2.15156 15.3834 1.98984 14.965C1.8668 14.6486 1.71914 14.1705 1.68047 13.2951C1.63828 12.3459 1.62773 12.0611 1.62773 9.65996C1.62773 7.25527 1.63828 6.97051 1.68047 6.0248C1.71914 5.1459 1.8668 4.67129 1.98984 4.35488C2.15156 3.93652 2.34844 3.63418 2.66133 3.32129C2.97773 3.00488 3.27656 2.81152 3.69492 2.6498C4.01133 2.52676 4.48945 2.3791 5.36484 2.34043C6.31055 2.29824 6.59531 2.2877 9 2.2877ZM9 0.666992C6.55664 0.666992 6.25078 0.677539 5.29102 0.719727C4.33477 0.761914 3.67734 0.916601 3.10781 1.13809C2.51367 1.37012 2.01094 1.67598 1.51172 2.17871C1.00898 2.67793 0.703125 3.18066 0.471094 3.77129C0.249609 4.34434 0.0949219 4.99824 0.0527344 5.95449C0.0105469 6.91777 0 7.22363 0 9.66699C0 12.1104 0.0105469 12.4162 0.0527344 13.376C0.0949219 14.3322 0.249609 14.9896 0.471094 15.5592C0.703125 16.1533 1.00898 16.6561 1.51172 17.1553C2.01094 17.6545 2.51367 17.9639 3.1043 18.1924C3.67734 18.4139 4.33125 18.5686 5.2875 18.6107C6.24727 18.6529 6.55312 18.6635 8.99648 18.6635C11.4398 18.6635 11.7457 18.6529 12.7055 18.6107C13.6617 18.5686 14.3191 18.4139 14.8887 18.1924C15.4793 17.9639 15.982 17.6545 16.4813 17.1553C16.9805 16.6561 17.2898 16.1533 17.5184 15.5627C17.7398 14.9896 17.8945 14.3357 17.9367 13.3795C17.9789 12.4197 17.9895 12.1139 17.9895 9.67051C17.9895 7.22715 17.9789 6.92129 17.9367 5.96152C17.8945 5.00527 17.7398 4.34785 17.5184 3.77832C17.2969 3.18066 16.991 2.67793 16.4883 2.17871C15.9891 1.67949 15.4863 1.37012 14.8957 1.1416C14.3227 0.920117 13.6688 0.76543 12.7125 0.723242C11.7492 0.677539 11.4434 0.666992 9 0.666992Z" fill="currentColor"/><path d="M9 5.04395C6.44766 5.04395 4.37695 7.11465 4.37695 9.66699C4.37695 12.2193 6.44766 14.29 9 14.29C11.5523 14.29 13.623 12.2193 13.623 9.66699C13.623 7.11465 11.5523 5.04395 9 5.04395ZM9 12.6658C7.34414 12.6658 6.00117 11.3229 6.00117 9.66699C6.00117 8.01113 7.34414 6.66816 9 6.66816C10.6559 6.66816 11.9988 8.01113 11.9988 9.66699C11.9988 11.3229 10.6559 12.6658 9 12.6658Z" fill="currentColor"/><path d="M14.8852 4.86104C14.8852 5.45869 14.4 5.94033 13.8059 5.94033C13.2082 5.94033 12.7266 5.45518 12.7266 4.86104C12.7266 4.26338 13.2117 3.78174 13.8059 3.78174C14.4 3.78174 14.8852 4.2669 14.8852 4.86104Z" fill="currentColor"/></g><defs><clipPath id="ig"><rect width="18" height="18" fill="white" transform="translate(0 0.666992)"/></clipPath></defs></svg>`;
const linkedinSvg = `<svg width="18" height="19" viewBox="0 0 18 19" fill="none" xmlns="http://www.w3.org/2000/svg"><g clip-path="url(#li)"><path d="M16.6676 0.666992H1.32891C0.594141 0.666992 0 1.24707 0 1.96426V17.3662C0 18.0834 0.594141 18.667 1.32891 18.667H16.6676C17.4023 18.667 18 18.0834 18 17.3697V1.96426C18 1.24707 17.4023 0.666992 16.6676 0.666992ZM5.34023 16.0057H2.66836V7.41348H5.34023V16.0057ZM4.0043 6.24277C3.14648 6.24277 2.45391 5.5502 2.45391 4.6959C2.45391 3.8416 3.14648 3.14902 4.0043 3.14902C4.85859 3.14902 5.55117 3.8416 5.55117 4.6959C5.55117 5.54668 4.85859 6.24277 4.0043 6.24277ZM15.3387 16.0057H12.6703V11.8291C12.6703 10.8342 12.6527 9.55098 11.2816 9.55098C9.89297 9.55098 9.68203 10.6373 9.68203 11.7588V16.0057H7.01719V7.41348H9.57656V8.5877H9.61172C9.9668 7.9127 10.8387 7.19902 12.1359 7.19902C14.8395 7.19902 15.3387 8.97793 15.3387 11.2912V16.0057Z" fill="currentColor"/></g><defs><clipPath id="li"><rect width="18" height="18" fill="white" transform="translate(0 0.666992)"/></clipPath></defs></svg>`;
const xSvg = `<svg width="18" height="19" viewBox="0 0 18 19" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M14.1757 1.53174H16.9357L10.9058 8.42425L18 17.8015H12.4455L8.0955 12.1135L3.117 17.8015H0.3555L6.8055 10.429L0 1.53249H5.6955L9.62775 6.73149L14.1757 1.53174ZM13.2075 16.15H14.7367L4.8645 3.09699H3.2235L13.2075 16.15Z" fill="currentColor"/></svg>`;
const youtubeSvg = `<svg width="18" height="19" viewBox="0 0 18 19" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17.8207 6.06709C17.8207 6.06709 17.6449 4.82607 17.1035 4.28115C16.418 3.56396 15.6516 3.56045 15.3 3.51826C12.7828 3.33545 9.00352 3.33545 9.00352 3.33545H8.99648C8.99648 3.33545 5.21719 3.33545 2.7 3.51826C2.34844 3.56045 1.58203 3.56396 0.896484 4.28115C0.355078 4.82607 0.182812 6.06709 0.182812 6.06709C0.182812 6.06709 0 7.52607 0 8.98154V10.3456C0 11.8011 0.179297 13.2601 0.179297 13.2601C0.179297 13.2601 0.355078 14.5011 0.892969 15.046C1.57852 15.7632 2.47852 15.7386 2.8793 15.8159C4.3207 15.953 9 15.9952 9 15.9952C9 15.9952 12.7828 15.9882 15.3 15.8089C15.6516 15.7667 16.418 15.7632 17.1035 15.046C17.6449 14.5011 17.8207 13.2601 17.8207 13.2601C17.8207 13.2601 18 11.8046 18 10.3456V8.98154C18 7.52607 17.8207 6.06709 17.8207 6.06709ZM7.14023 12.0015V6.94248L12.0023 9.48076L7.14023 12.0015Z" fill="currentColor"/></svg>`;
---

<footer class="footer">
  <div class="noise-bg" aria-hidden="true"></div>
  <div class="line-wrapper bottom-left-lines" aria-hidden="true">
    <div class="lines short"></div>
    <div class="lines narrow"></div>
  </div>
  <div class="line-wrapper top-right-lines" aria-hidden="true">
    <div class="lines short"></div>
    <div class="lines narrow"></div>
  </div>

  <div class="container">
    <div class="footer-wrap">

      <!-- Top: brand info + nav menus -->
      <div class="footer-top">
        <div class="footer-info">
          <a href="/" aria-label="AllSafe IT — home">
            <div class="footer__logo">
              <img
                src={logoWhite.src}
                alt=""
                class="footer-logo"
                width="140"
                height="43"
                loading="lazy"
                decoding="async"
              />
            </div>
            {/* sr-only text gives crawlers real anchor text without
                affecting the visible UI. The icon's alt is empty +
                aria-hidden so the link's accessible name comes from
                this span, not duplicated by the image. */}
            <span class="sr-only">AllSafe IT home</span>
          </a>
          <p class="lead-text color__white-shade1">
            We&rsquo;re an IT company serving Los Angeles and Orange County. Small enough to know your
            name. Big enough to have your back. SOC2 compliant and obsessively process-driven, because
            tech should support you, not the other way around.
          </p>
          <a href="/contact-us" class="button small">talk to an expert</a>
        </div>

        <nav class="footer-menus" aria-label="Footer navigation">
          <!-- Main pages -->
          <div class="footer-menu-wrap">
            <div class="footer-menu">
              <div class="footer-head color__white-shade1">[Main pages]</div>
              <a href="/" class="footer-link">Home</a>
              <a href="/services/it-infrastructure-and-cloud" class="footer-link">Infrastructure &amp; Cloud</a>
              <a href="/services/managed-it" class="footer-link">Managed IT</a>
              <a href="/services/it-consulting" class="footer-link">IT Consulting</a>
              <a href="/services/cybersecurity" class="footer-link">Cybersecurity</a>
              <a href="/industries" class="footer-link">Industries</a>
              <a href="/areas-we-serve" class="footer-link">Areas We Serve</a>
            </div>
          </div>

          <!-- Our story -->
          <div class="footer-menu-wrap">
            <div class="footer-menu">
              <div class="footer-head color__white-shade1">[our story]</div>
              <a href="/about-us" class="footer-link">About Us</a>
              <a href="/why-choose-us" class="footer-link">Why Choose Us</a>
              <a href="/support" class="footer-link">Remote Support</a>
              <a href="/testimonials" class="footer-link">Testimonials</a>
              <a href="/careers" class="footer-link">Careers</a>
              <a href="/blog" class="footer-link">Blog</a>
              <a href="/contact-us" class="footer-link">Contact</a>
            </div>
          </div>

          <!-- Locations + contact -->
          <div class="footer-menu-wrap">
            <div class="footer-menu">
              <div class="footer-head color__white-shade1">[Locations]</div>
              <a href="/locations/managed-it-services-pasadena" class="footer-link">Pasadena</a>
              <a href="/locations/managed-it-services-los-angeles" class="footer-link">Los Angeles</a>
              <a href="/locations/managed-it-services-orange-county" class="footer-link">Orange County</a>
            </div>
            <div class="footer-menu">
              <div class="footer-head color__white-shade1">[Contact us]</div>
              <a href="tel:+18884002748" class="footer-link flex">
                <span class="footer-icon" set:html={phoneSvg} />
                <span>Sales<br />(888) 400-2748<br />option 1</span>
              </a>
              <a href="tel:+12137841959" class="footer-link flex">
                <span class="footer-icon" set:html={phoneSvg} />
                <span>Support<br />(213) 784-1959</span>
              </a>
            </div>
          </div>
        </nav>
      </div>

      <!-- Office locations -->
      <div class="footer-contact">
        <div class="footer-head color__white-shade1 text-center">[our locations]</div>
        <div class="footer-menu flex">
          <address class="footer-link flex">
            <span class="footer-icon" set:html={pinSvg} />
            <span>Pasadena:<br />70 South Lake Ave, Suite 690<br />Pasadena, CA 91101</span>
          </address>
          <address class="footer-link flex">
            <span class="footer-icon" set:html={pinSvg} />
            <span>Los Angeles:<br />1800 North Vine St<br />Los Angeles, CA 90028</span>
          </address>
          <address class="footer-link flex">
            <span class="footer-icon" set:html={pinSvg} />
            <span>Orange County:<br />4695 MacArthur Court<br />Newport Beach, CA 92660</span>
          </address>
        </div>
      </div>

      <!-- Bottom bar -->
      <div class="footer-bottom">
        <div class="copyright-wrap">
          <p class="small-text copyright-text">&copy; Copyright {year} AllSafe IT</p>
        </div>
        <div class="social-links">
          {/* Each social link has an sr-only label so SEO crawlers and
              screen readers see real anchor text rather than nothing
              (aria-label kept for redundancy + tooltips on some
              assistive tech). */}
          <a href="https://www.instagram.com/allsafeit/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="AllSafe IT on Instagram">
            <span class="social-link-icon" aria-hidden="true" set:html={instagramSvg} />
            <span class="sr-only">AllSafe IT on Instagram</span>
          </a>
          <a href="https://www.linkedin.com/company/allsafe-it" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="AllSafe IT on LinkedIn">
            <span class="social-link-icon" aria-hidden="true" set:html={linkedinSvg} />
            <span class="sr-only">AllSafe IT on LinkedIn</span>
          </a>
          <a href="https://x.com/allsafeit" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="AllSafe IT on X">
            <span class="social-link-icon" aria-hidden="true" set:html={xSvg} />
            <span class="sr-only">AllSafe IT on X</span>
          </a>
          <a href="https://www.youtube.com/@AllSafeIT" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="AllSafe IT on YouTube">
            <span class="social-link-icon" aria-hidden="true" set:html={youtubeSvg} />
            <span class="sr-only">AllSafe IT on YouTube</span>
          </a>
        </div>
      </div>

      <!-- Disclaimer -->
      <p class="small-text footer-disclaimer">
        Our proactive IT support approach ensures your business is equipped to face any IT challenge.
        Partner with us today for worry-free tech.
      </p>

    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background-color: var(--color-brand-dark);
    color: var(--color-text-light);
    padding-top: 96px;
    padding-bottom: 72px;
    overflow: hidden;
  }

  /* Noise texture overlay */
  .noise-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: url('/images/Noise.avif');
    background-size: auto;
    opacity: 0.4;
    z-index: 0;
  }

  /* Decorative line strips */
  .line-wrapper {
    position: absolute;
    z-index: 0;
    pointer-events: none;
  }

  .bottom-left-lines { bottom: 0; left: 0; }
  .top-right-lines { top: 0; right: 0; }

  .container {
    position: relative;
    z-index: 1;
    max-width: var(--container-main);
    padding-left: var(--container-gutter);
    padding-right: var(--container-gutter);
    margin-left: auto;
    margin-right: auto;
  }

  .footer-wrap {
    display: flex;
    flex-direction: column;
    gap: 72px;
  }

  /* ── Top section ────────────────────────────────────────────── */
  .footer-top {
    display: flex;
    gap: 48px;
    justify-content: space-between;
    align-items: flex-start;
  }

  .footer-info {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: var(--container-4col);
  }

  .footer__logo {
    max-width: 140px;
  }

  .footer-logo {
    width: 140px;
    height: 43px;
    object-fit: contain;
  }

  /* ── Nav menus ──────────────────────────────────────────────── */
  .footer-menus {
    display: flex;
    gap: 48px;
    flex-wrap: wrap;
  }

  .footer-menu-wrap {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .footer-menu {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-head {
    font-family: var(--font-badges);
    font-size: var(--text-small);
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 0.05em;
    opacity: 0.6;
  }

  .footer-link {
    color: var(--color-text-light);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    transition: opacity 0.2s;
    text-decoration: none;
  }

  .footer-link:hover {
    opacity: 0.7;
  }

  .footer-link.flex,
  address.footer-link {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-style: normal;
  }

  .footer-icon {
    flex-shrink: 0;
    margin-top: 3px;
    opacity: 0.7;
  }

  /* ── Locations bar ──────────────────────────────────────────── */
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 24px;
    border-top: 1px dotted var(--color-light-1-faded);
    padding-top: 48px;
  }

  .footer-contact .footer-menu.flex {
    display: flex;
    flex-direction: row;
    gap: 48px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .text-center {
    text-align: center;
  }

  /* ── Bottom bar ─────────────────────────────────────────────── */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px dotted var(--color-light-1-faded);
    padding-top: 24px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .small-text {
    font-size: var(--text-small);
    line-height: var(--leading-small);
    opacity: 0.6;
  }

  .copyright-text {
    margin: 0;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .social-link {
    display: flex;
    align-items: center;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .social-link:hover {
    opacity: 1;
  }

  .footer-disclaimer {
    margin: 0;
    text-align: center;
  }

  /* ── Button (local) ─────────────────────────────────────────── */
  .button.small {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--btn-height-sm);
    padding: 0 var(--btn-px-sm);
    border-radius: var(--radius-default);
    background-color: var(--color-brand-primary);
    color: var(--color-text-light);
    font-family: var(--font-badges);
    font-size: var(--text-small);
    font-weight: 500;
    text-transform: uppercase;
    text-decoration: none;
    align-self: flex-start;
  }

  /* ── color__white-shade1 utility ────────────────────────────── */
  .color__white-shade1 {
    color: var(--color-light-2);
  }

  /* ── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 991px) {
    .footer-top {
      flex-direction: column;
    }

    .footer-info {
      max-width: 100%;
    }

    .footer-menus {
      gap: 32px;
    }

    .footer-contact .footer-menu.flex {
      flex-direction: column;
      gap: 24px;
    }
  }

  @media (max-width: 479px) {
    .footer-menus {
      flex-direction: column;
      gap: 24px;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
