---
/**
 * WhyChooseAccordion — collapsible accordion next to a sticky image.
 *
 * Each item is a native <details>/<summary> (no blocking JS): closed by
 * default, opens on click. Webflow's `.accordion-content-wrap` collapses
 * via JS — native disclosure gives us the same UX with zero JS cost. A
 * green check icon sits before each title (matches Webflow's `widget__embed-icons.green-icon`).
 */
import Icon from '../primitives/Icon.astro';

interface Item {
  label: string;
  body: string;
  /** Optional inline SVG markup for the item icon. Falls back to a green check. */
  icon?: string;
  /** Optional extra class on widget__embed-icons wrapper. */
  iconClass?: string;
}

interface Props {
  heading: string;
  intro: string;
  items: Item[];
  image: string;
  imageAlt: string;
  /** Cybersecurity "Additional services" places image on the left, accordion on the right. */
  imageLeft?: boolean;
  /** Default 'gradient'. IT-consulting "process works" section uses no background. */
  bg?: 'gradient' | 'plain';
}

const { heading, intro, items, image, imageAlt, imageLeft = false, bg = 'gradient' } = Astro.props;
const bgClass = bg === 'gradient' ? ' bg-gradient' : '';
---

<div class={`section${bgClass}`}>
  <div class="container">
    <div class="section-content">
      <div class={`grid${imageLeft ? ' image-left' : ''}`}>
        {imageLeft && (
          <div class="square-image-wrap sticky">
            <img
              src={image}
              alt={imageAlt}
              class="square-parallax-image"
              width="500"
              height="500"
              loading="lazy"
            />
          </div>
        )}

        <div class="justify-vertical">
          <div class="content">
            <h2 class="h3">{heading}</h2>
            <p class="lead-text" set:html={intro}></p>
          </div>
          <div class="accordion">
            {items.map(item => (
              <details class="why-item">
                <summary class="why-summary">
                  <div class="accordion-icon-title">
                    {item.icon ? (
                      <div class={`widget__embed-icons${item.iconClass ? ' ' + item.iconClass : ''}`} set:html={item.icon} />
                    ) : (
                      <Icon name="check-circle" class="widget__embed-icons green-icon" />
                    )}
                    <div class="accordion-title no_padding">{item.label}</div>
                  </div>
                  <span class="why-chevron" aria-hidden="true"></span>
                </summary>
                <div class="why-content">
                  <p class="body-text accordion-text" set:html={item.body}></p>
                </div>
              </details>
            ))}
          </div>
        </div>

        {!imageLeft && (
          <div class="square-image-wrap sticky">
            <img
              src={image}
              alt={imageAlt}
              class="square-parallax-image"
              width="500"
              height="500"
              loading="lazy"
            />
          </div>
        )}
      </div>
    </div>
  </div>
</div>

<style>
  /* Webflow `.accordion` — column flex, 12px gaps between items. */
  .accordion {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 1.5rem;
  }

  /* Webflow `.accordion-item` — bordered card, rounded, click-to-expand. */
  .why-item {
    border: 1px solid var(--color-dark-border, #3b3b331c);
    border-radius: var(--radius-default);
    background-color: transparent;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }
  .why-item[open] {
    border-color: var(--color-brand-dark);
  }

  .why-summary {
    cursor: pointer;
    list-style: none;
    padding: 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    user-select: none;
  }
  .why-summary::-webkit-details-marker { display: none; }
  .why-summary::marker { content: ''; }

  .accordion-icon-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-width: 0;
  }

  .accordion-title.no_padding {
    color: var(--color-brand-dark);
    padding: 0;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.3;
  }

  /* Webflow `.widget__embed-icons.green-icon` — 2rem icon, green tint. */
  .widget__embed-icons {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .widget__embed-icons :global(svg) {
    width: 100%;
    height: 100%;
  }
  .widget__embed-icons.green-icon {
    color: var(--color-icon-green, #1ea66a);
  }

  /* CSS-only chevron — flips on [open] to give a clear toggle affordance
     (the only visible difference from the Problems accordion, which is
     iconless / arrowless per Webflow). */
  .why-chevron {
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    border-right: 2px solid var(--color-brand-dark);
    border-bottom: 2px solid var(--color-brand-dark);
    transform: rotate(45deg);
    transition: transform 0.2s ease;
  }
  .why-item[open] .why-chevron { transform: rotate(-135deg); }

  /* Webflow `.accordion-content` — body padded under the title row, 18px
     side padding to align with the summary. */
  .why-content {
    padding: 0 18px 1.25rem;
  }
  /* Inherit size from the .body-text class on the markup — keeps text in
     this section consistent with the rest of the page (.body-text in
     global.css = --text-lead, 18px). */
  .accordion-text {
    margin: 0;
    color: var(--color-text-dark-body);
  }

  @media (max-width: 767px) {
    .accordion-title.no_padding { font-size: 1.1rem; }
  }
</style>
