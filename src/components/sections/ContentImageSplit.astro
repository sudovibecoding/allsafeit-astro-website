---
import Icon from '../primitives/Icon.astro';

interface Button {
  label: string;
  href: string;
  style?: 'button' | 'link';
}

interface Props {
  heading?: string;
  headingHtml?: string;
  bodyHtml: string;
  image: string;
  imageAlt: string;
  imageRight?: boolean;
  bg?: 'gradient' | 'white';
  buttons?: Button[];
}

const {
  heading,
  headingHtml,
  bodyHtml,
  image,
  imageAlt,
  imageRight = false,
  bg = 'white',
  buttons = [],
} = Astro.props;
const bgClass = bg === 'gradient' ? 'bg-gradient' : '';
---

<div class={`section ${bgClass}`}>
  <div class="container">
    <div class="section-content">
      <div class={`split-grid ${imageRight ? 'img-right' : ''}`}>
        <div class="square-image-wrap">
          <img
            src={image}
            alt={imageAlt}
            class="square-parallax-image"
            width="600"
            height="600"
            loading="lazy"
          />
        </div>
        <div class="content">
          {headingHtml ? (
            <Fragment set:html={headingHtml} />
          ) : (
            <h2 class="h3">{heading}</h2>
          )}
          {bodyHtml && <Fragment set:html={bodyHtml} />}
          {buttons.length > 0 && (
            <div class="button-row">
              {buttons.map((btn) =>
                btn.style === 'link' ? (
                  <a href={btn.href} class="icon-button-link">
                    <div class="circle-button">
                      <div class="circle-button-icon-wrapper">
                        <Icon name="custom-arrow" class="icon--arrow" />
                      </div>
                    </div>
                    <span class="badge-text">{btn.label}</span>
                  </a>
                ) : (
                  <a href={btn.href} class="button">
                    {btn.label}
                  </a>
                ),
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .split-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .split-grid.img-right .square-image-wrap {
    order: 2;
  }
  .split-grid.img-right .content {
    order: 1;
  }

  .square-image-wrap {
    border-radius: var(--radius-default);
    overflow: hidden;
    aspect-ratio: 1;
  }

  .square-parallax-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    align-items: center;
  }

  @media (max-width: 991px) {
    .split-grid {
      grid-template-columns: 1fr;
    }
    .split-grid.img-right .square-image-wrap {
      order: -1;
    }
    .split-grid.img-right .content {
      order: 0;
    }
    .square-image-wrap {
      max-height: 320px;
    }
  }
</style>
