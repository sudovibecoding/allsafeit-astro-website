---
interface Item {
  /** The bold colored term at the start of the list item. */
  term: string;
  /** The body text after the term. HTML allowed for inline anchors. */
  body: string;
}

interface Props {
  heading: string;
  /** Optional intro paragraph rendered above the list. */
  intro?: string;
  /** Ordered list items. */
  items: Item[];
  /** Optional closing paragraph below the list. */
  outro?: string;
  /** Right-column sticky image. */
  image: string;
  imageAlt: string;
  /** Background style — primary uses gradient, secondary uses gradient as well per export. */
  bg?: 'gradient' | 'plain';
}

const { heading, intro, items, outro, image, imageAlt, bg = 'gradient' } = Astro.props;
const sectionClass = `section${bg === 'gradient' ? ' bg-gradient' : ''}`;
---

<div class={sectionClass}>
  <div class="container">
    <div class="section-content">
      <div class="numbered-grid">
        <div class="numbered-content">
          <h2 class="h3">{heading}</h2>
          {intro && <p class="lead-text">{intro}</p>}
          <ol class="numbered-list body-text">
            {items.map(item => (
              <li><strong class="color__lightblue">{item.term}</strong> <span set:html={item.body}></span></li>
            ))}
          </ol>
          {outro && <p class="lead-text">{outro}</p>}
        </div>
        <div class="numbered-img-wrap">
          <img
            src={image}
            alt={imageAlt}
            class="numbered-img"
            width="600"
            height="600"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .numbered-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .numbered-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .numbered-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-left: 1.5rem;
    margin: 0;
  }

  .numbered-list li {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--color-brand-dark);
  }

  .numbered-img-wrap {
    position: sticky;
    top: calc(var(--navbar-height) + 2rem);
  }

  .numbered-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-default);
    object-fit: cover;
    aspect-ratio: 1;
  }

  @media (max-width: 991px) {
    .numbered-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .numbered-img-wrap { position: static; }
  }
</style>
