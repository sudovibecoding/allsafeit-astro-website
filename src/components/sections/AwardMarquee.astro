---
import { Image } from 'astro:assets';
import badgeCrn from '../../assets/images/badges/CRN_MSP-500_optimized.avif';
import badgeMedallion from '../../assets/images/badges/inc-500-medallion-optimized.avif';
import badgeInc154 from '../../assets/images/badges/inc-154.avif';
import badgeInc2024 from '../../assets/images/badges/Inc-2024-optmized.avif';
import badgeClutchHelp from '../../assets/images/badges/top_clutch.co_help_desk_service_provider_los_angeles_2023.avif';
import badgeClutchIT from '../../assets/images/badges/top_clutch.co_it_services_company_retail_california.avif';
import badgeBBB from '../../assets/images/badges/BBBrating.avif';
import badgeAICPA from '../../assets/images/badges/AICPA-Logo-1.avif';
import badgeInc124 from '../../assets/images/badges/american_fastest__growing__company-124.avif';
import badgeIncFastest from '../../assets/images/badges/american_fastest__growing__company.avif';

interface Props {
  title?: string;
}

const { title = 'Award winning MSP in CA' } = Astro.props;
---

<section class="section padding-small">
  <div class="marquee_container">
    <div class="logo-section">
      <p class="h5">{title}</p>
      <div class="marquee">
        <div class="marquee-group">
          <div class="marquee-logos">
            <div class="marqueelogo__holder"><Image src={badgeCrn} alt="CRN MSP 500 2025 logo" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeMedallion} alt="Inc. 5000 Color Medallion Logo" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeInc154} alt="Inc 5000 2024 badge" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeInc2024} alt="Inc. 5000 badge for fastest-growing private companies in America, ranked 2052 in 2024" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeClutchHelp} alt="Top help desk service provider badge" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeClutchIT} alt="Top IT services company badge" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeBBB} alt="BBB Accredited Business badge" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeAICPA} alt="AICPA Logo" class="marquee-logo" width={100} loading="lazy" /></div>
          </div>
        </div>
        <div class="marquee-group" aria-hidden="true">
          <div class="marquee-logos">
            <div class="marqueelogo__holder"><Image src={badgeCrn} alt="" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeMedallion} alt="" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeInc124} alt="" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeIncFastest} alt="" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeClutchHelp} alt="" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeClutchIT} alt="" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeBBB} alt="" class="marquee-logo" width={100} loading="lazy" /></div>
            <div class="marqueelogo__holder"><Image src={badgeAICPA} alt="" class="marquee-logo" width={100} loading="lazy" /></div>
          </div>
        </div>
        <div class="marquee-scrim" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .marquee_container {
    width: 100%;
    max-width: var(--container-main);
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow: hidden;
  }

  .logo-section {
    gap: 1rem;
    border-bottom: 1px dotted var(--color-dark-faded);
    text-align: center;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    padding-bottom: 72px;
    display: flex;
  }

  .marquee {
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    position: relative;
    overflow: hidden;
  }

  .marquee-group {
    flex: none;
    animation: marquee-scroll 30s linear infinite;
  }

  .marquee-logos {
    gap: 2rem;
    justify-content: flex-start;
    align-items: center;
    padding-right: 72px;
    display: flex;
  }

  .marqueelogo__holder {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .marquee-logo {
    object-fit: contain;
    flex-shrink: 0;
    height: auto;
  }

  .marquee-scrim {
    z-index: 1;
    pointer-events: none;
    background-image: linear-gradient(270deg, #fff, #fdfdfd00 10% 90%, #f5f7f9e6 99%, #fff);
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-100%); }
  }

  @media (max-width: 767px) {
    .marquee-logo { width: 100px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-group { animation: none; }
  }
</style>
