---
/**
 * Tabs — Webflow-style tabbed content (menu on the left, panel on the right;
 * stacks on mobile). Clicking a tab on the left swaps the panel on the right.
 *
 * Architecture / "slim build" note (per request):
 *   This is NOT a framework island. A React/Preact island would pull a
 *   framework runtime (~130KB for React) onto the page — against the goal of
 *   a slim, JS-light public site (which currently ships zero framework JS to
 *   visitors). Instead this is progressive enhancement: every pane is rendered
 *   server-side (great for SEO + no-JS fallback shows the first tab), and a
 *   tiny deferred `<script>` (~0.5KB, non-blocking module) just toggles which
 *   pane is visible. Same pattern as the site's slider/nav scripts.
 *
 * Props:
 *   tabs    — [{ label, content }]; `content` is HTML (rendered with set:html)
 *   initial — index of the tab open on load (default 0)
 */
interface TabItem {
  label: string;
  content: string;
}
interface Props {
  tabs: TabItem[];
  initial?: number;
}
const { tabs, initial = 0 } = Astro.props;
---

<div class="tabs" data-tabs>
  <div class="tabs-menu" role="tablist" aria-orientation="vertical">
    {tabs.map((t, i) => (
      <button
        type="button"
        class={`tab-link${i === initial ? ' is-active' : ''}`}
        role="tab"
        aria-selected={i === initial ? 'true' : 'false'}
        data-tab-link={String(i)}
      >
        <h3 class="heading-19">{t.label}</h3>
      </button>
    ))}
  </div>

  <div class="tabs-content">
    {tabs.map((t, i) => (
      <div
        class={`tab-pane${i === initial ? ' is-active' : ''}`}
        role="tabpanel"
        data-tab-pane={String(i)}
        hidden={i !== initial}
      >
        <div class="tab_content">
          <p class="h4">{t.label}</p>
          <div class="lead-text" set:html={t.content}></div>
        </div>
      </div>
    ))}
  </div>
</div>

<!-- Tab-switching JS lives in src/scripts/tabs.ts, lazy-loaded by init.ts
     only on pages that contain [data-tabs] (same pattern as the slider). -->

<style>
  /* 30% menu / 70% content — matches Webflow `.tabs-2`. Grid (not flex)
     avoids the "60% of *remaining* space after gap" rounding that was
     causing the right edge to clip. `minmax(0, …fr)` prevents the content
     column from being forced wider than its grid track by long tables/text. */
  .tabs {
    display: grid;
    grid-template-columns: minmax(0, 30fr) minmax(0, 70fr);
    gap: 2rem;
    align-items: flex-start;
    padding: 2rem 0;
  }
  .tabs-menu {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }
  .tabs-content {
    min-width: 0;
  }

  /* Webflow `.tab-link-tab-N` — full-width pill, soft border, dark text. */
  .tab-link {
    display: block;
    width: 100%;
    text-align: left;
    cursor: pointer;
    background: transparent;
    border: 1px solid var(--color-dark-border, #3b3b331c);
    padding: 1rem 1.25rem;
    border-radius: var(--radius-default);
    color: var(--color-brand-dark);
    transition: background-color 0.2s ease, color 0.2s ease,
                border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .tab-link:hover {
    border-color: var(--color-brand-dark);
  }
  .tab-link .heading-19 {
    margin: 0;
    font-size: var(--text-h6);
    line-height: 1.3;
    font-weight: 500;
    color: inherit;
    text-align: left;
  }
  /* Active tab — Webflow `.w--current`: dark fill, light text, accent
     left border + soft lift. */
  .tab-link.is-active {
    background-color: var(--color-brand-dark);
    color: var(--color-light-1);
    border-color: var(--color-brand-dark);
    border-left: 3px solid var(--color-accent);
    box-shadow: 0 8px 24px #00000026;
  }

  .tab-pane[hidden] { display: none; }
  .tab_content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }
  .tab_content .h4 { margin: 0; }
  /* Force any long words / inline code in the panel to wrap rather than
     pushing the column wider than the grid track. */
  .tab_content :global(*) {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  @media (max-width: 991px) {
    .tabs {
      grid-template-columns: 1fr;
      padding: 1rem 0;
    }
  }
</style>
