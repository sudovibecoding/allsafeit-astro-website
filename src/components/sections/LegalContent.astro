---
interface Props {
  title: string;
  lastUpdated?: string;
}

const { title, lastUpdated } = Astro.props;
---

<div aria-hidden="true" style="height: var(--navbar-height)"></div>

<section class="section legal-hero">
  <div class="container">
    <h1 class="h2">{title}</h1>
    {lastUpdated && <p class="version-text">{lastUpdated}</p>}
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="legal-grid">
      <div class="legal-body richtext">
        <slot />
      </div>
      <aside class="legal-sidebar">
        <div class="sidebar-card">
          <h3 class="h5">Have Additional Questions?</h3>
          <p class="body-text">Contact us directly and we'll get back to you within one business day.</p>
          <div class="sidebar-contacts">
            <a href="tel:+18884002748" class="sidebar-contact-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.79a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              888-400-2748
            </a>
            <a href="mailto:info@allsafeit.com" class="sidebar-contact-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              info@allsafeit.com
            </a>
          </div>
          <a href="/contact-us" class="button small">
            <div class="button-text-wrapper">
              <span class="button-text">Send us a message</span>
            </div>
          </a>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .legal-hero {
    background: var(--color-light-2, #f5f7fa);
    padding-bottom: 2rem;
  }

  .version-text {
    margin-top: 0.5rem;
    font-size: var(--text-lead);
    color: var(--color-text-base);
    opacity: 0.7;
  }

  .legal-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 4rem;
    align-items: start;
  }

  .richtext h2 {
    font-size: var(--text-h4);
    font-weight: 600;
    color: var(--color-brand-dark);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .richtext h3 {
    font-size: var(--text-h5);
    font-weight: 600;
    color: var(--color-brand-dark);
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .richtext p {
    font-size: var(--text-lead);
    line-height: var(--leading-lead);
    color: var(--color-brand-dark);
    margin-bottom: 1rem;
  }

  .richtext ul,
  .richtext ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .richtext li {
    font-size: var(--text-lead);
    line-height: var(--leading-lead);
    color: var(--color-brand-dark);
    margin-bottom: 0.4rem;
  }

  .sidebar-card {
    position: sticky;
    top: calc(var(--navbar-height) + 2rem);
    background: var(--color-light-2, #f5f7fa);
    border-radius: var(--radius-default);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sidebar-contacts {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .sidebar-contact-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-brand-dark);
    text-decoration: none;
    font-size: var(--text-lead);
    font-weight: 500;
    transition: color 0.15s ease;
  }

  .sidebar-contact-link:hover { color: var(--color-accent); }

  @media (max-width: 991px) {
    .legal-grid {
      grid-template-columns: 1fr;
    }

    .sidebar-card { position: static; }
  }
</style>
